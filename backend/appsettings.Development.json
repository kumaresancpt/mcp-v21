{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=mcp_visitors;Username=postgres;Password=Database@123"
  },
  "Jwt": {
    "Secret": "your-super-secret-jwt-key-change-in-production-12345678901234567890",
    "ExpiryMinutes": 30,
    "Issuer": "vms-api",
    "Audience": "vms-frontend"
  },
  "Session": {
    "InactivityTimeoutMinutes": 30,
    "ExtendByMinutes": 30
  },
  "Lockout": {
    "MaxFailedAttempts": 5,
    "LockoutDurationMinutes": 15
  },
  "Otp": {
    "ValidMinutes": 10,
    "MaxAttempts": 3,
    "LengthDigits": 6
  },
  "Email": {
    "SmtpHost": "smtp.example.com",
    "SmtpPort": 587,
    "SenderEmail": "noreply@vms.local",
    "SenderName": "VMS - Visitor Management System",
    "Username": "dev@vms.local",
    "Password": "dev-password",
    "EnableSsl": true
  },
  "PasswordPolicy": {
    "MinLength": 8,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireSpecial": true,
    "HistoryCount": 5
  },
  "RateLimiting": {
    "LoginWindowSeconds": 60,
    "LoginMaxRequests": 10
  },
  "NotificationSettings": {
    "ApprovalTimeoutMinutes": 30,
    "ReminderIntervalMinutes": 15,
    "PhotoSignedUrlValidityDays": 7,
    "DraftExpiryHours": 4,
    "ApprovalNotificationDelaySec": 30
  },
  "ObjectStore": {
    "Type": "LocalStorage",
    "BucketName": "vms-photos",
    "AccessKeyId": "",
    "SecretAccessKey": ""
  },
  "Sms": {
    "Provider": "Twilio",
    "AccountSid": "",
    "AuthToken": "",
    "FromNumber": ""
  },
  "WhatsApp": {
    "Provider": "Twilio",
    "PhoneNumberId": "",
    "BusinessAccountId": "",
    "ApiKey": ""
  },
  "AppSettings": {
    "PhotoBaseUrl": "http://localhost:5000/api/photos"
  }
}
