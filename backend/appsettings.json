{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=${DB_NAME};Username=${DB_USERNAME};Password=${DB_PASSWORD}"
  },
  "Jwt": {
    "Secret": "REPLACE_WITH_STRONG_SECRET_KEY_MINIMUM_32_CHARACTERS",
    "ExpiryMinutes": 30,
    "Issuer": "vms-api",
    "Audience": "vms-frontend"
  },
  "Session": {
    "InactivityTimeoutMinutes": 30,
    "ExtendByMinutes": 30
  },
  "Lockout": {
    "MaxFailedAttempts": 5,
    "LockoutDurationMinutes": 15
  },
  "Otp": {
    "ValidMinutes": 10,
    "MaxAttempts": 3,
    "LengthDigits": 6
  },
  "Email": {
    "SmtpHost": "smtp.example.com",
    "SmtpPort": 587,
    "SenderEmail": "noreply@changepond.com",
    "SenderName": "VMS - Visitor Management System",
    "Username": "REPLACE_WITH_SMTP_USERNAME",
    "Password": "REPLACE_WITH_SMTP_PASSWORD",
    "EnableSsl": true
  },
  "PasswordPolicy": {
    "MinLength": 8,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireSpecial": true,
    "HistoryCount": 5
  },
  "RateLimiting": {
    "LoginWindowSeconds": 60,
    "LoginMaxRequests": 10
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  }
}
