{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=mcp_visitors;Username=postgres;Password={DB_PASSWORD}"
  },
  "Jwt": {
    "Secret": "REPLACE_WITH_STRONG_SECRET_KEY_MINIMUM_32_CHARACTERS",
    "ExpiryMinutes": 30,
    "Issuer": "vms-api",
    "Audience": "vms-frontend"
  },
  "Session": {
    "InactivityTimeoutMinutes": 30,
    "ExtendByMinutes": 30
  },
  "Lockout": {
    "MaxFailedAttempts": 5,
    "LockoutDurationMinutes": 15
  },
  "Otp": {
    "ValidMinutes": 10,
    "MaxAttempts": 3,
    "LengthDigits": 6
  },
  "Email": {
    "SmtpHost": "smtp.example.com",
    "SmtpPort": 587,
    "SenderEmail": "noreply@changepond.com",
    "SenderName": "VMS - Visitor Management System",
    "Username": "REPLACE_WITH_SMTP_USERNAME",
    "Password": "REPLACE_WITH_SMTP_PASSWORD",
    "EnableSsl": true
  },
  "PasswordPolicy": {
    "MinLength": 8,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireSpecial": true,
    "HistoryCount": 5
  },
  "RateLimiting": {
    "LoginWindowSeconds": 60,
    "LoginMaxRequests": 10
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  },
  "NotificationSettings": {
    "ApprovalTimeoutMinutes": 30,
    "ReminderIntervalMinutes": 15,
    "PhotoSignedUrlValidityDays": 7,
    "DraftExpiryHours": 4,
    "ApprovalNotificationDelaySec": 30
  },
  "ObjectStore": {
    "Type": "LocalStorage",
    "BucketName": "vms-photos",
    "AccessKeyId": "REPLACE_WITH_ACCESS_KEY",
    "SecretAccessKey": "REPLACE_WITH_SECRET_KEY"
  },
  "Sms": {
    "Provider": "Twilio",
    "AccountSid": "REPLACE_WITH_ACCOUNT_SID",
    "AuthToken": "REPLACE_WITH_AUTH_TOKEN",
    "FromNumber": "+1234567890"
  },
  "WhatsApp": {
    "Provider": "Twilio",
    "PhoneNumberId": "REPLACE_WITH_PHONE_NUMBER_ID",
    "BusinessAccountId": "REPLACE_WITH_BUSINESS_ACCOUNT_ID",
    "ApiKey": "REPLACE_WITH_API_KEY"
  },
  "AppSettings": {
    "PhotoBaseUrl": "http://localhost:8000/api/photos"
  },
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_STRONG_SECRET_KEY_MINIMUM_32_CHARACTERS"
  }
}
